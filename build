#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_NAME="Menubar Native Control"
APP_PATH="$ROOT_DIR/.build/$APP_NAME.app"
INSTALL_DIR="${INSTALL_DIR:-/Applications}"
INSTALLED_APP_PATH="$INSTALL_DIR/$APP_NAME.app"

usage() {
    cat <<USAGE
Usage:
  ./build <command> [command ...]

Commands:
  run       Run the app through SwiftPM
  archive   Build and package .build/$APP_NAME.app
  install   Copy the archived app to \$INSTALL_DIR/$APP_NAME.app
  clean     Remove SwiftPM build artifacts

Examples:
  ./build archive
  ./build archive install
  INSTALL_DIR="\$HOME/Applications" ./build archive install
USAGE
}

archive_app() {
    "$ROOT_DIR/Scripts/package-app.sh" >/dev/null
    echo "Archived: $APP_PATH"
}

install_app() {
    if [[ ! -d "$APP_PATH" ]]; then
        echo "Archive missing; building it first."
        archive_app
    fi

    mkdir -p "$INSTALL_DIR"
    if [[ -d "$INSTALLED_APP_PATH" ]]; then
        rm -rf "$INSTALLED_APP_PATH"
    fi
    ditto "$APP_PATH" "$INSTALLED_APP_PATH"
    echo "Installed: $INSTALLED_APP_PATH"
}

if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

cd "$ROOT_DIR"

for command in "$@"; do
    case "$command" in
        run)
            CLANG_MODULE_CACHE_PATH="$ROOT_DIR/.build/clang-module-cache" swift run MenubarNativeControl
            ;;
        archive)
            archive_app
            ;;
        install)
            install_app
            ;;
        clean)
            swift package clean
            ;;
        help|-h|--help)
            usage
            ;;
        *)
            echo "Unknown command: $command" >&2
            usage >&2
            exit 64
            ;;
    esac
done
